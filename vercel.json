{
  "functions": {
    "api/export-pdf.js": {
      "maxDuration": 60
    },
    "api/export-data.js": {
      "maxDuration": 10
    },
    "api/send-reminders.js": {
      "maxDuration": 30
    },
    "api/export-content-plan-pdf.js": {
      "maxDuration": 60
    },
    "api/export-content-plan-data.js": {
      "maxDuration": 10
    },
    "api/export-content-plan-docx.js": {
      "maxDuration": 15
    },
    "api/share-content-plan.js": {
      "maxDuration": 10
    },
    "api/get-content-plan-public.js": {
      "maxDuration": 10
    },
    "api/update-content-plan-item.js": {
      "maxDuration": 10
    },
    "api/billing/process-recurring.js": {
      "maxDuration": 60
    },
    "api/billing/sms-optin.js": {
      "maxDuration": 10
    },
    "api/billing/sms-optin-confirm.js": {
      "maxDuration": 10
    },
    "api/twilio/voice.js": {
      "maxDuration": 10
    },
    "api/twilio/sms.js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/billing/process-recurring",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}